# Copy to .env and adjust. Docker Compose reads this file automatically.

# --- Postgres ---
POSTGRES_USER=pesawise
POSTGRES_PASSWORD=pesawise
POSTGRES_DB=pesawise
# Host port the containerized DB is exposed on (5433 avoids clashing with a local Postgres on 5432)
DB_HOST_PORT=5433

# --- Host ports for the app ---
# 8080 avoids Windows/Hyper-V reserved port ranges that often include 4200.
WEB_HOST_PORT=8080
API_HOST_PORT=3000

# --- Backend ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
# Same-origin in Docker (nginx proxies /api), so '*' is fine for the demo.
CORS_ORIGIN=*
# Seed the demo personas on first boot (skips itself once data exists).
AUTO_SEED=true
